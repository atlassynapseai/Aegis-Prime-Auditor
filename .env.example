# Enterprise Deployment Configuration
# Copy to .env.local or set in Railway environment variables

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
NODE_ENV=production
DEBUG=false

# ============================================================================
# SUPABASE (Multi-Tenant Database)
# ============================================================================
SUPABASE_URL=https://guodrtwqhbnnjrbfkbxs.supabase.co
SUPABASE_ANON_KEY=sb_publishable_RSi6gvoGNvyvKy5ALKfFXg_BCcHMnGp
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imd1b2RydHdxaGJubmpyYmZrYnhzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjU0MTY3MiwiZXhwIjoyMDg4MTE3NjcyfQ.BywIApRxE5Hyr4qthkCEXzBOVgGOI7EiBxmrDPCQ8gw

# Migration phase (1=dual-write, 2=read-switching, 3=supabase-only, 4=archive)
MIGRATION_PHASE=1
SUPABASE_WRITE_ENABLED=true

# ============================================================================
# SECURITY & ENCRYPTION
# ============================================================================
# Generate securely: openssl rand -base64 64
JWT_SECRET=agWnBH47xh15lXdUUa5tFqeMmVzilh8v3KFS6P4iGZh4DZyCBII4ksnbssYkN8j8zdqz4O+blixIqhFD/MQKpA==

# Generate securely: openssl rand -base64 32 (for AES-256-GCM)
ENCRYPTION_KEY=oWSxu5bey6Iri7t+W9dmVR+2R0UPXuNLV7HLbKgQ4aI=

# ============================================================================
# API KEYS & EXTERNAL SERVICES
# ============================================================================
# Gemini API for AI analysis
OPENAI_API_KEY=your_gemini_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# VirusTotal for malware detection
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AlienVault OTX for threat intelligence
ALIENVAULT_OTX_API_KEY=your_otx_api_key_here

# ============================================================================
# OBSERVABILITY (Sprint 6)
# ============================================================================
# Datadog for structured logging and metrics
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_SITE=datadoghq.com
DATADOG_SERVICE=aegis-auditor
DATADOG_ENV=production

# Prometheus metrics endpoint
PROMETHEUS_PORT=9090

# Jaeger for distributed tracing
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# ============================================================================
# DATABASE (Scanning)
# ============================================================================
SCAN_TIMEOUT_SECONDS=120
MAX_UPLOAD_SIZE_MB=50

# ============================================================================
# CI/CD INTEGRATION
# ============================================================================
# GitHub
GITHUB_ORG=atlassynapseai
GITHUB_TOKEN=ghp_your_personal_access_token

# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=glpat_your_token

# ============================================================================
# BILLING (Sprint 10)
# ============================================================================
# Stripe for subscription management
STRIPE_API_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================================
# SSO PROVIDERS (Sprint 9)
# ============================================================================
# Okta
OKTA_DOMAIN=https://dev-12345.okta.com
OKTA_CLIENT_ID=your_okta_client_id
OKTA_CLIENT_SECRET=your_okta_client_secret

# Azure AD
AZURE_AD_TENANT_ID=your_tenant_id
AZURE_AD_CLIENT_ID=your_client_id
AZURE_AD_CLIENT_SECRET=your_client_secret

# ============================================================================
# STORAGE (S3 for artifacts)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=aegis-auditor-artifacts
S3_BUCKET_REGION=us-east-1

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=/var/log/aegis-auditor.log

# ============================================================================
# RAILWAY DEPLOYMENT
# ============================================================================
# Port for service
PORT=8000

# Memory allocation (MB)
RAILWAY_MEMORY=1024

# CPU allocation (milli-cores)
RAILWAY_CPU=1000

# ============================================================================
# COMPLIANCE FLAGS
# ============================================================================
# Enable HIPAA-specific encryption and audit requirements
ENABLE_HIPAA=true

# Enable GDPR data residency and right-to-delete policies
ENABLE_GDPR=true

# Enable SOC 2 audit logging and MFA enforcement
ENABLE_SOC2=true

# Enable NYDFS-23-NYCRR-500 specific requirements
ENABLE_NYDFS=true

# ============================================================================
# FEATURE FLAGS (used in migration phases)
# ============================================================================
FEATURE_DUAL_WRITE=true
FEATURE_JWT_AUTH=true
FEATURE_MULTI_TENANCY=true
FEATURE_SHAP_EXPLAINABILITY=false  # Sprint 5
FEATURE_DRIFT_DETECTION=false      # Sprint 7
FEATURE_SSO=false                   # Sprint 9
FEATURE_BILLING=false               # Sprint 10
