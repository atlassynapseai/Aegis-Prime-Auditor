# Aegis Prime Auditor - Environment Configuration
# Copy this file to .env and fill in your values

# Gemini API (Get your key at: https://aistudio.google.com/apikey)
OPENAI_API_KEY=your-gemini-api-key-here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Server Configuration
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_DEBUG=false

# Scanner Paths (auto-detected if on PATH)
SEMGREP_PATH=semgrep
GITLEAKS_PATH=gitleaks
TRIVY_PATH=trivy

# Scan Limits
MAX_UPLOAD_SIZE_MB=50
SCAN_TIMEOUT_SECONDS=120
